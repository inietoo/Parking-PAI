// ===== SERVO SIN LIBRERÍAS - ESP32 CON PWM NATIVO =====

// Pin on està connectat el senyal del servo
const int SERVO_PIN = 18;

// Canal PWM LEDC de l'ESP32 que es farà servir per generar el senyal del servo
const int PWM_CHANNEL = 0;      // Canal LEDC (0-15)

// Freqüència típica d’un servo estàndard: 50 Hz = període de 20 ms
const int PWM_FREQUENCY = 50;   // 50 Hz para servo estándar

// Resolució del PWM en bits; 16 bits = valors de 0 a 65535 aproximadament
const int PWM_RESOLUTION = 16;  // 16-bit resolución

// Mapeo: 20ms ciclo total (50Hz)
// 1ms pulse = 0°  → 3277 ticks
// 1.5ms pulse = 90° → 4915 ticks
// 2ms pulse = 180° → 6553 ticks
// Aquests valors indiquen quin duty PWM correspon a cada angle del servo.[web:48][web:61]

const int SERVO_MIN = 3277;   // Valor PWM aproximat per angle mínim
const int SERVO_MAX = 6553;   // Valor PWM aproximat per angle màxim

// ===== PUERTA AUTOMÀTICA ESP32 - SENSE LLIBRERIES =====
// Pins originals mantinguts: Servo(18), LEDs(26,25), Sensor(5,4)

// LEDs y Sensor

// LED verd
const int GREEN = 26;

// LED roig
const int RED = 25;

// AQUÍ TORNES A DECLARAR SERVO_PIN.
// Això és un problema perquè SERVO_PIN ja estava declarat abans.
// En un sketch real això dona error o conflicte.[web:65][web:71]
const int SERVO_PIN = 18;

// Mateix pin del LED verd però amb un altre nom
const int LED_VERD = 26;

// Mateix pin del LED roig però amb un altre nom
const int LED_ROIG = 25;

// Pin TRIG del sensor ultrasònic HC-SR04
const int TRIG_PIN = 5;

// Pin ECHO del sensor ultrasònic HC-SR04
const int ECHO_PIN = 4;

// Variables globals

// Variable global on es guardarà la distància llegida
long distancia = 0;

// Funció per mesurar la distància amb el sensor ultrasònic
long mesurarDistancia() {

  // Posem TRIG a LOW per assegurar una arrencada neta
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  // Enviem un pols de 10 microsegons al TRIG per activar el sensor
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  // pulseIn espera quant temps el pin ECHO està a HIGH
  // amb un timeout de 30000 microsegons per no quedar bloquejat massa estona.[web:64][web:70]
  long duracio = pulseIn(ECHO_PIN, HIGH, 30000);

  // Si no arriba cap eco dins del timeout, retorna 999 com a valor especial
  if (duracio == 0) return 999;

  // Converteix duració a distància en cm:
  // velocitat del so aproximada 0.034 cm/us i dividim entre 2 (anada i tornada)
  return duracio * 0.034 / 2;
}

// Mover servo a ángulo específico (0-180°)
void servoWrite(int angle) {

  // Converteix l’angle 0-180 a un valor PWM entre SERVO_MIN i SERVO_MAX
  int pwmValue = map(angle, 0, 180, SERVO_MIN, SERVO_MAX);

  // Escriu aquest valor al canal PWM de l’ESP32
  ledcWrite(PWM_CHANNEL, pwmValue);

// Control servo amb pulsos manuals (sense ledc)
void mouServo(int angle) {

  // Aquesta funció és l’altra manera de controlar el servo:
  // en lloc d’usar LEDC, genera polsos manuals amb digitalWrite.
  // Però aquí està enganxada dins l’altra funció perquè falta una } abans.
  // Tal com està, el codi està mal tancat i no compilarà.[web:65]

  // Converteix angle a pols entre 1000 i 2000 microsegons
  int ampladaPulso = map(angle, 0, 180, 1000, 2000);
  
  // 10 cicles complets (200ms)
  for(int i = 0; i < 10; i++) {

    // Comença el pols en HIGH
    digitalWrite(SERVO_PIN, HIGH);

    // Manté HIGH el temps corresponent a l’angle
    delayMicroseconds(ampladaPulso);

    // Baixa el pin a LOW
    digitalWrite(SERVO_PIN, LOW);

    // Completa fins als 20 ms totals del cicle del servo
    delayMicroseconds(20000 - ampladaPulso);
  }
}

void setup() {

  // Configura el PWM LEDC de l’ESP32
  ledcSetup(PWM_CHANNEL, PWM_FREQUENCY, PWM_RESOLUTION);

  // Assigna el pin del servo al canal PWM
  ledcAttachPin(SERVO_PIN, PWM_CHANNEL);

  // LEDs
  // Configura els LEDs com a sortida
  pinMode(GREEN, OUTPUT);
  pinMode(RED, OUTPUT);

  // Inicia comunicació sèrie
  Serial.begin(115200);
  Serial.println("🚪 Puerta automatica iniciada");

  // Sensor ultrasónico
  // Configurar pins

  // Torna a configurar el pin del servo com OUTPUT manual,
  // però això es barreja amb l’ús de LEDC i no és ideal
  pinMode(SERVO_PIN, OUTPUT);

  // Configura LEDs amb els altres noms duplicats
  pinMode(LED_VERD, OUTPUT);
  pinMode(LED_ROIG, OUTPUT);

  // Configura sensor
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  // Estado inicial

  // Mou el servo a angle 5º amb PWM LEDC
  servoWrite(5);

  // Encén LED roig i apaga verd
  digitalWrite(RED, HIGH);
  digitalWrite(GREEN, LOW);

  // AQUEST Serial.begin ESTÀ DUPLICAT
  // No passa res greu, però és innecessari
  Serial.begin(115200);
  
  // Estat inicial: porta tancada, llum vermella

  // Torna a moure el servo però ara amb la funció manual
  // Això mostra clarament que has barrejat dos sistemes diferents de control
  mouServo(5);

  // Torna a posar l’estat dels LEDs
  digitalWrite(LED_ROIG, HIGH);
  digitalWrite(LED_VERD, LOW);
  
  // Espera inicial
  delay(1000);
}

void loop() {

  // Llegeix la distància i la guarda a una variable local d
  long d = mesurarDistancia();

  // Imprimeix només el número per sèrie
  Serial.println(d);

  // Puerta cerrada por defecto

  // Manté servo tancat amb la funció LEDC
  servoWrite(5);

  // Estat LED tancat
  digitalWrite(RED, HIGH);
  digitalWrite(GREEN, LOW);

  // Si objeto a menos de 10cm: abrir puerta
  if (d <= 10) {

    // Si la distància és menor o igual a 10 cm, apaga roig i encén verd
    digitalWrite(RED, LOW);
    digitalWrite(GREEN, HIGH);

    // Obre la porta amb el servo
    servoWrite(90);

    // Manté oberta 2 segons
    delay(2000);

  // A PARTIR D’AQUÍ COMENÇA UNA SEGONA LÒGICA ENGANXADA DINS DEL MATEIX LOOP
  // Això està mal estructurat perquè sembla que falta tancar l’if o el bloc anterior

  distancia = mesurarDistancia();

  // Escriu text + distància
  Serial.print("Distancia: ");
  Serial.print(distancia);
  Serial.println(" cm");
  
  // Porta tancada per defecte

  // Ara torna a tancar la porta, però amb l’altra funció manual
  mouServo(5);

  // Torna a posar LEDs amb els noms catalans
  digitalWrite(LED_ROIG, HIGH);
  digitalWrite(LED_VERD, LOW);
  
  // Objeto detectat < 10cm -> obrir porta
  if (distancia <= 10 && distancia > 0) {

    // Si detecta objecte proper, mostra missatge
    Serial.println("🔓 Obrint porta...");

    // Encén LED verd i apaga roig
    digitalWrite(LED_ROIG, LOW);
    digitalWrite(LED_VERD, HIGH);

    // Obre la porta amb la funció manual
    mouServo(90);

    // Manté la porta oberta 3 segons
    delay(3000);  // Manté 3 segons

    // Missatge indicant que es tanca
    Serial.println("🔒 Tancant porta...");
  }

  // Petita espera
  delay(100);
  
  // Una altra espera extra
  delay(200);
}
